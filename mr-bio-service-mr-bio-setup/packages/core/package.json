    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.3.7",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/lodash": "^4.17.0",

    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.614.0",
    "@aws-sdk/s3-request-presigner": "^3.614.0",
    "@dotenvx/dotenvx": "^0.35.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.3.0",
    "axios": "^1.6.8",
    "cookie-parser": "^1.4.6",
    "cron": "^3.1.7",
    "ioredis": "^5.5.0",
    "luxon": "^3.4.4",
    "mongodb": "^6.5.0",

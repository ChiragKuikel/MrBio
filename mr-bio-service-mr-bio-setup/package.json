{
  "name": "mr-bio",
  "private": true,
  "scripts": {
    "create-feature": "ts-node cli/cli.ts create-feature",
    "create-repo-contents": "ts-node cli/cli.ts create-repo-contents",
    "create-microservice": "ts-node cli/cli.ts create-microservice",
    "build": "turbo build",
    "start": "turbo start",
    "gateway:start": "turbo run start --filter=gateway",
    "user-auth:start": "turbo run start --filter=user-auth",
    "communication:start": "turbo run start --filter=communication",
    "activity-log:start": "turbo run start --filter=activity-log",
    "product:start": "turbo run start --filter=product",
    "local": "turbo local",
    "server": "turbo server",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "test": "turbo test",
    "test:failedOnly": "jest --onlyFailures",
    "test:watch": "turbo test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@mr-bio/core": "*",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-license-header": "^0.6.1",
    "eslint-plugin-perfectionist": "^2.10.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.3.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@nestjs/microservices": "^10.3.8",
    "compression": "^1.7.5",
    "db-mongo-migration": "^1.13.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "kafkajs": "^2.2.4"
  }
}

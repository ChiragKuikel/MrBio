{
  "name": "@mr-bio/core",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "exports": {
    "./tsconfig-base.json": "./tsconfig-base.json",
    ".": {
      "types": "./src/app/index.ts",
      "default": "./dist/app/index.js"
    },
    "./shared": {
      "types": "./src/shared/index.ts",
      "default": "./dist/shared/index.js"
